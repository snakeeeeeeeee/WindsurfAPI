# ========== Server ==========
PORT=3003
# API key for incoming requests (leave empty for open access)
API_KEY=
# Directory for persisted JSON state and logs (Docker 推荐用 /data)
DATA_DIR=

# ========== Codeium Auth ==========
# Option 1: Direct API key from Windsurf
CODEIUM_API_KEY=

# Option 2: Token from windsurf.com/show-auth-token
CODEIUM_AUTH_TOKEN=

# ========== Language Server ==========
# Path to language_server_linux_x64 binary
LS_BINARY_PATH=/opt/windsurf/language_server_linux_x64
# gRPC port for language server
LS_PORT=42100

# ========== Dashboard ==========
# Dashboard password — protects /dashboard and all /dashboard/api/* endpoints.
# If empty AND API_KEY is also empty, dashboard is completely open (anyone can
# view accounts, API keys, logs, and trigger updates). Set this for any
# internet-facing deployment.
DASHBOARD_PASSWORD=

# ========== Advanced ==========
CODEIUM_API_URL=https://server.self-serve.windsurf.com
DEFAULT_MODEL=claude-4.5-sonnet-thinking
MAX_TOKENS=8192
LOG_LEVEL=info

# ========== Cascade Reuse / Real Upstream Cache ==========
# 真实 Cascade 会话复用相关配置，会影响上游真实请求的复用/cache_r，不只是展示。
# Claude Code / Cline 等客户端的 system prompt 每轮可能带 cwd、时间、环境快照，导致 hash 漂移、reuse MISS。
# 设为 0 时，复用 fingerprint 不再包含 system prompt，更容易命中真实 Cascade 复用；推荐先试这个。
# 留空表示默认严格模式：system prompt 参与 hash。
CASCADE_REUSE_HASH_SYSTEM=
# 高风险开关：共享 API key 且没有 metadata.user_id/user/session_id 等用户维度时，也强制允许 Cascade 复用。
# new-api 多用户共用一个 key 时不建议开启，否则可能出现跨用户/跨终端串 Cascade 会话。
# 只有确认是单用户私有部署，或 new-api 已经稳定透传每个用户/终端的隔离字段时，才考虑设为 1。
CASCADE_REUSE_ALLOW_SHARED_API_KEY=

# Report-only usage overrides for downstream dashboards/billing relays.
# Does not change real upstream cache behavior; only rewrites returned usage fields.
# Accepts 0.8, 80, or 80%.
WINDSURFAPI_REPORTED_CACHE_HIT_RATE=
# Example: set to 1 to report prompt_tokens/input_tokens as 1.
WINDSURFAPI_REPORTED_INPUT_TOKENS=
# Anthropic /v1/messages-only report-only usage rewriting.
# 仅改写返回给下游/new-api/CCTest 看到的 usage，不影响真实上游请求和模型对话。
WINDSURFAPI_ANTHROPIC_REPORTED_CACHE_BUCKETS=
# upstream：生产推荐，保留真实上游返回的 cache_read/cache_write，适合 new-api 真实计费。
# official：检测/展示用，按 Anthropic 官方 prompt caching 口径模拟 cache_control 命中/写入。
# client：按原始 Anthropic 请求 payload 估算，再配合下面的命中率/创建倍率硬改写。
# 真实业务推荐 upstream；CCTest 外观测试才考虑 official。
WINDSURFAPI_ANTHROPIC_REPORTED_USAGE_BASIS=
# upstream：保留上游返回的 output_tokens，生产推荐。
# response：按最终返回给用户的内容估算输出 tokens，适合检测/展示，可能偏离真实上游输出计费。
WINDSURFAPI_ANTHROPIC_REPORTED_OUTPUT_BASIS=
# report-only 缓存模拟器最大记录数，只存 hash/token/过期时间，不存 prompt 原文。
WINDSURFAPI_ANTHROPIC_REPORTED_CACHE_MAX_ENTRIES=
# official 模式用：命中已有 prefix 后，新尾部 cache creation 的保守比例上限，默认 0.15。
WINDSURFAPI_ANTHROPIC_REPORTED_CACHE_CREATION_TAIL_RATIO=
# 旧 client/upstream 模式用：强制 fresh input tokens，例如 1。official 模式建议留空。
WINDSURFAPI_ANTHROPIC_REPORTED_FRESH_INPUT_TOKENS=
# 旧 client/upstream 模式用：强制可见缓存命中率。official 模式建议留空。
WINDSURFAPI_ANTHROPIC_REPORTED_CACHE_HIT_RATE=
# 旧 client/upstream 模式用：缩放 cache creation，例如 0.5、50、50%。official 模式建议留空。
WINDSURFAPI_ANTHROPIC_REPORTED_CACHE_CREATION_RATE=

# Public model aliases exposed to downstream clients/new-api/CPA.
# 公开模型名映射：左边是外部看到/请求的模型名，右边是 WindsurfAPI 内部真实路由模型。
# 示例：外部看到 claude-opus-4-7，但内部实际跑 claude-opus-4-7-medium。
# 支持逗号分隔；每项支持 public=target 或 public=>target。
WINDSURFAPI_PUBLIC_MODEL_ALIASES=
# 设为 1 时，/v1/models 只展示 public alias，隐藏被 alias 指向的内部 target。
# 例如隐藏 claude-opus-4-7-medium，只暴露 claude-opus-4-7。
WINDSURFAPI_PUBLIC_MODEL_ALIAS_HIDE_TARGETS=

# ========== Security ==========
# Allow private/internal hosts (e.g., 192.168.x.x, 10.x.x.x, localhost) in proxy tests.
# Set to 1 for local deployments where you need to test proxies on private networks.
# Leave empty or set to 0 for public-facing deployments (default: only public hosts allowed).
ALLOW_PRIVATE_PROXY_HOSTS=
