# ========== Server ==========
PORT=3003
# API key for incoming requests (leave empty for open access)
API_KEY=
# 持久化 SQLite 数据库、旧 JSON 备份和日志的目录（Docker 推荐用 /data）
DATA_DIR=
# SQLite 长期配置数据库。Docker 默认使用 /data/windsurfapi.sqlite；
# 首次空库会从旧 JSON 导入一次，之后以 SQLite 为准，旧 JSON 保留作备份。
WINDSURFAPI_SQLITE_PATH=/data/windsurfapi.sqlite
WINDSURFAPI_DB_IMPORT_JSON_ON_EMPTY=1

# ========== Codeium Auth ==========
# Option 1: Direct API key from Windsurf
CODEIUM_API_KEY=

# Option 2: Token from windsurf.com/show-auth-token
CODEIUM_AUTH_TOKEN=

# ========== Language Server ==========
# Path to language_server_linux_x64 binary
LS_BINARY_PATH=/opt/windsurf/language_server_linux_x64
# gRPC port for language server
LS_PORT=42100

# ========== Dashboard ==========
# Dashboard password — protects /dashboard and all /dashboard/api/* endpoints.
# If empty AND API_KEY is also empty, dashboard is completely open (anyone can
# view accounts, API keys, logs, and trigger updates). Set this for any
# internet-facing deployment.
DASHBOARD_PASSWORD=

# ========== Advanced ==========
CODEIUM_API_URL=https://server.self-serve.windsurf.com
DEFAULT_MODEL=claude-4.5-sonnet-thinking
MAX_TOKENS=8192
LOG_LEVEL=info

# ========== 可用性 / 高可用调度 ==========
# Redis 用来共享账号冷却、模型 breaker、健康账号池等调度状态。
# Docker Compose 默认会注入 redis://windsurf-api-redis:6379；裸机部署可以留空，
# 留空时只使用当前进程内存状态，重启或多实例之间不会共享。
WINDSURFAPI_REDIS_URL=redis://windsurf-api-redis:6379
# off = 关闭；conservative = 保守模式；aggressive = 激进可用模式。
WINDSURFAPI_AVAILABILITY_MODE=aggressive
# 每次手动/模型探测最多检查多少个账号。
WINDSURFAPI_PROBE_CONCURRENCY_PER_MODEL=3
# 后台恢复探测并发限制，会在 Dashboard/runtime-config 中展示和覆盖。
WINDSURFAPI_BACKGROUND_PROBE_PER_MODEL=2
WINDSURFAPI_BACKGROUND_PROBE_GLOBAL=5
# 在指定时间窗口内出现 N 次 rate-limit 后，将模型 breaker 置为 degraded/open。
WINDSURFAPI_MODEL_BREAKER_THRESHOLD=3
WINDSURFAPI_MODEL_BREAKER_WINDOW_MS=3000
WINDSURFAPI_MODEL_BREAKER_MIN_MS=60000
# off = 不自动 fallback；same_family = 只在同系列/同档位族内 fallback。
WINDSURFAPI_AUTO_FALLBACK=same_family
# 主动高可用 Worker：后台周期探测账号容量和关注模型可用性，减少用户请求首次踩冷却。
WINDSURFAPI_AVAILABILITY_WORKER_ENABLED=1
# Worker 每轮间隔、批量大小和单轮最长运行时间；Dashboard 保存后会覆盖这些默认值。
WINDSURFAPI_AVAILABILITY_WORKER_INTERVAL_MS=60000
WINDSURFAPI_AVAILABILITY_WORKER_BATCH_ACCOUNTS=20
WINDSURFAPI_AVAILABILITY_WORKER_BATCH_MODELS=4
# cheap_only = 只做账号容量探测；selective_model = 只探重点/异常模型；aggressive_model = 轮转探测关注模型。
WINDSURFAPI_AVAILABILITY_WORKER_PROBE_MODE=selective_model
WINDSURFAPI_AVAILABILITY_WORKER_JITTER_MS=5000
WINDSURFAPI_AVAILABILITY_WORKER_MAX_RUNTIME_MS=30000
# 模型热账号池：每个关注模型至少维护多少个新鲜成功账号、最多保留多少条记录。
WINDSURFAPI_HOT_POOL_MIN_PER_MODEL=5
WINDSURFAPI_HOT_POOL_MAX_PER_MODEL=30
WINDSURFAPI_HOT_POOL_FRESH_MS=600000
# 用户请求冷启动时是否允许用小 prompt 并发探测账号；不会并发发送真实用户 prompt。
WINDSURFAPI_REQUEST_PROBE_ENABLED=1
WINDSURFAPI_REQUEST_PROBE_CONCURRENCY=3
WINDSURFAPI_REQUEST_PROBE_BUDGET_MS=2000
# 真实请求刚开始遇到 rate limit 时，最多快速换几个账号以及总预算。
WINDSURFAPI_FAST_SWITCH_MAX_ATTEMPTS=2
WINDSURFAPI_FAST_SWITCH_BUDGET_MS=3000
# 账号最近失败/限流后的评分惩罚窗口。
WINDSURFAPI_ACCOUNT_SCORE_FAILURE_PENALTY_MS=300000
# Dashboard 模型状态/手动探测默认关注的模型匹配规则；支持逗号分隔和 * 通配。
# 默认只关注 Claude Sonnet 4.6、Opus 4.6、Opus 4.7、Haiku 4.5 系列。
WINDSURFAPI_AVAILABILITY_TRACKED_MODEL_PATTERNS=claude-4.5-haiku,claude-sonnet-4.6,claude-opus-4.6,claude-opus-4-7-low,claude-opus-4-7-medium,claude-opus-4-7-high,claude-opus-4-7-xhigh,claude-opus-4-7-max

# ========== 动态代理 IP / 账号级粘性出口 ==========
# 是否启用账号级动态代理绑定。启用后仍需在 Dashboard 执行绑定/换 IP，或开启自动绑定新账号。
WINDSURFAPI_DYNAMIC_PROXY_ENABLED=0
# 当前内置 Novproxy 模板；每个账号生成独立 sid，默认粘性 120 分钟。
WINDSURFAPI_DYNAMIC_PROXY_PROVIDER=novproxy
WINDSURFAPI_DYNAMIC_PROXY_PROTOCOL=http
WINDSURFAPI_DYNAMIC_PROXY_HOST=us.novproxy.io
WINDSURFAPI_DYNAMIC_PROXY_PORT=1000
WINDSURFAPI_DYNAMIC_PROXY_USERNAME_TEMPLATE=nfgr68136-region-{region}-st-{state}-sid-{sid}-t-{ttl}
WINDSURFAPI_DYNAMIC_PROXY_PASSWORD=
WINDSURFAPI_DYNAMIC_PROXY_REGION=US
WINDSURFAPI_DYNAMIC_PROXY_STATE=New Jersey
WINDSURFAPI_DYNAMIC_PROXY_TTL_MINUTES=120
# 到期前多久由 Worker 自动换绑新 IP。
WINDSURFAPI_DYNAMIC_PROXY_RENEW_BEFORE_MS=900000
# 绑定前使用该地址验证代理出口；ipinfo 会返回 IP/地区/运营商信息。
WINDSURFAPI_DYNAMIC_PROXY_VERIFY_URL=https://ipinfo.io/json
WINDSURFAPI_DYNAMIC_PROXY_MAX_BIND_RETRIES=3
# 新增账号后是否自动绑定动态 IP；默认关闭，生产可在 Dashboard 打开。
WINDSURFAPI_DYNAMIC_PROXY_AUTO_BIND_NEW_ACCOUNTS=0
# 动态 IP Worker：周期维护过期/失败/未绑定账号。
WINDSURFAPI_DYNAMIC_PROXY_WORKER_INTERVAL_MS=60000
WINDSURFAPI_DYNAMIC_PROXY_WORKER_BATCH_SIZE=20
WINDSURFAPI_DYNAMIC_PROXY_WORKER_CONCURRENCY=3

# ========== Cascade Reuse / Real Upstream Cache ==========
# 真实 Cascade 会话复用相关配置，会影响上游真实请求的复用/cache_r，不只是展示。
# Claude Code / Cline 等客户端的 system prompt 每轮可能带 cwd、时间、环境快照，导致 hash 漂移、reuse MISS。
# 设为 0 时，复用 fingerprint 不再包含 system prompt，更容易命中真实 Cascade 复用；推荐先试这个。
# 留空表示默认严格模式：system prompt 参与 hash。
CASCADE_REUSE_HASH_SYSTEM=
# 高风险开关：共享 API key 且没有 metadata.user_id/user/session_id 等用户维度时，也强制允许 Cascade 复用。
# new-api 多用户共用一个 key 时不建议开启，否则可能出现跨用户/跨终端串 Cascade 会话。
# 只有确认是单用户私有部署，或 new-api 已经稳定透传每个用户/终端的隔离字段时，才考虑设为 1。
CASCADE_REUSE_ALLOW_SHARED_API_KEY=

# Report-only usage overrides for downstream dashboards/billing relays.
# Does not change real upstream cache behavior; only rewrites returned usage fields.
# Accepts 0.8, 80, or 80%.
WINDSURFAPI_REPORTED_CACHE_HIT_RATE=
# Example: set to 1 to report prompt_tokens/input_tokens as 1.
WINDSURFAPI_REPORTED_INPUT_TOKENS=
# Anthropic /v1/messages-only report-only usage rewriting.
# 仅改写返回给下游/new-api/CCTest 看到的 usage，不影响真实上游请求和模型对话。
WINDSURFAPI_ANTHROPIC_REPORTED_CACHE_BUCKETS=
# upstream：生产推荐，保留真实上游返回的 cache_read/cache_write，适合 new-api 真实计费。
# official：检测/展示用，按 Anthropic 官方 prompt caching 口径模拟 cache_control 命中/写入。
# client：按原始 Anthropic 请求 payload 估算，再配合下面的命中率/创建倍率硬改写。
# 真实业务推荐 upstream；CCTest 外观测试才考虑 official。
WINDSURFAPI_ANTHROPIC_REPORTED_USAGE_BASIS=
# upstream：保留上游返回的 output_tokens，生产推荐。
# response：按最终返回给用户的内容估算输出 tokens，适合检测/展示，可能偏离真实上游输出计费。
WINDSURFAPI_ANTHROPIC_REPORTED_OUTPUT_BASIS=
# report-only 缓存模拟器最大记录数，只存 hash/token/过期时间，不存 prompt 原文。
WINDSURFAPI_ANTHROPIC_REPORTED_CACHE_MAX_ENTRIES=
# official 模式用：命中已有 prefix 后，新尾部 cache creation 的保守比例上限，默认 0.15。
WINDSURFAPI_ANTHROPIC_REPORTED_CACHE_CREATION_TAIL_RATIO=
# 旧 client/upstream 模式用：强制 fresh input tokens，例如 1。official 模式建议留空。
WINDSURFAPI_ANTHROPIC_REPORTED_FRESH_INPUT_TOKENS=
# 旧 client/upstream 模式用：强制可见缓存命中率。official 模式建议留空。
WINDSURFAPI_ANTHROPIC_REPORTED_CACHE_HIT_RATE=
# 旧 client/upstream 模式用：缩放 cache creation，例如 0.5、50、50%。official 模式建议留空。
WINDSURFAPI_ANTHROPIC_REPORTED_CACHE_CREATION_RATE=

# Public model aliases exposed to downstream clients/new-api/CPA.
# 公开模型名映射：左边是外部看到/请求的模型名，右边是 WindsurfAPI 内部真实路由模型。
# 示例：外部看到 claude-opus-4-7，但内部实际跑 claude-opus-4-7-medium。
# 支持逗号分隔；每项支持 public=target 或 public=>target。
WINDSURFAPI_PUBLIC_MODEL_ALIASES=
# 设为 1 时，/v1/models 只展示 public alias，隐藏被 alias 指向的内部 target。
# 例如隐藏 claude-opus-4-7-medium，只暴露 claude-opus-4-7。
WINDSURFAPI_PUBLIC_MODEL_ALIAS_HIDE_TARGETS=

# ========== Security ==========
# Allow private/internal hosts (e.g., 192.168.x.x, 10.x.x.x, localhost) in proxy tests.
# Set to 1 for local deployments where you need to test proxies on private networks.
# Leave empty or set to 0 for public-facing deployments (default: only public hosts allowed).
ALLOW_PRIVATE_PROXY_HOSTS=
